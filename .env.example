# Copy this file to .env and fill in your values
# Get credentials from: https://console.cloud.google.com/
# Enable: YouTube Data API v3

# YouTube Music OAuth (for ytmusicapi)
# Create OAuth 2.0 Client ID -> Desktop app or TVs and Limited Input devices
YTMUSIC_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
YTMUSIC_CLIENT_SECRET=your_client_secret_here
